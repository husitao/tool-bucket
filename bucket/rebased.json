{
    "version": "1.1.6",
    "description": "Rebased",
    "homepage": "https://github.com/DetachHead/rebased",
    "license": "Unknown",

    "url": "https://github.com/DetachHead/rebased/releases/download/1.1.6/rebased.exe",
    "hash": "3824CBAB72F134DBD7DA702D2977FE80F7B8B97A057F868F2E955108C1A78A0A",

    "extract_dir": "$PLUGINSDIR",

    "persist": [
        "config",
        "system"
    ],

    "installer": {
        "script": [
            "$vmoptions=Get-ChildItem \"$dir\\bin\" *.vmoptions | Select-Object -First 1",

            "if($vmoptions){",
                "$content=Get-Content $vmoptions.FullName",

                "$content=$content | Where-Object {",
                "    $_ -notmatch '^-Didea\\.config\\.path=' -and",
                "    $_ -notmatch '^-Didea\\.system\\.path=' -and",
                "    $_ -notmatch '^-Didea\\.log\\.path=' -and",
                "    $_ -notmatch '^-Didea\\.plugins\\.path='",
                "}",

                "$content += '-Didea.config.path='+($persist_dir+'\\config')",
                "$content += '-Didea.system.path='+($persist_dir+'\\system')",
                "$content += '-Didea.log.path='+($persist_dir+'\\system\\log')",
                "$content += '-Didea.plugins.path='+($persist_dir+'\\config\\plugins')",

                "Set-Content $vmoptions.FullName $content",
            "}"
        ]
    },

    "bin": [
        [
            "bin\\idea64.exe",
            "rebased"
        ]
    ],

    "shortcuts": [
        [
            "bin\\idea64.exe",
            "Rebased"
        ]
    ],

    "checkver": {
        "github": "https://github.com/DetachHead/rebased"
    },

    "autoupdate": {
        "url": "https://github.com/DetachHead/rebased/releases/download/$version/rebased.exe"
    }
}
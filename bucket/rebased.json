{
    "version": "1.1.8",
    "description": "Rebased",
    "homepage": "https://github.com/DetachHead/rebased",
    "license": "Unknown",

    "url": "https://gh-proxy.org/https://github.com/DetachHead/rebased/releases/download/1.1.8/rebased.exe#/dl.7z",
    "hash": "3B18053AB7E4017338E4C37898D7BE4767DECC036B8057BBFF298E445B6BB978",

    "pre_install": [
        "Remove-Item \"$dir\\`$PLUGINSDIR\" -Recurse -Force -ErrorAction SilentlyContinue"
    ],

    "persist": [
        "config",
        "system"
    ],

    "installer": {
        "script": [

            "$vmoptions = Join-Path $dir 'bin\\rebased64.exe.vmoptions'",

            "if (Test-Path $vmoptions) {",
                "$content=Get-Content $vmoptions",

                "$content = $content | Where-Object {",
                "    $_ -notmatch '^-Didea\\.config\\.path=' -and",
                "    $_ -notmatch '^-Didea\\.system\\.path=' -and",
                "    $_ -notmatch '^-Didea\\.log\\.path=' -and",
                "    $_ -notmatch '^-Didea\\.plugins\\.path='",
                "}",

                "$content += '-Didea.config.path='+($persist_dir+'\\config')",
                "$content += '-Didea.system.path='+($persist_dir+'\\system')",
                "$content += '-Didea.log.path='+($persist_dir+'\\system\\log')",
                "$content += '-Didea.plugins.path='+($persist_dir+'\\config\\plugins')",

                "Set-Content $vmoptions $content -Encoding UTF8",
            "}"
        ]
    },

    "bin": [
        [
            "bin\\rebased64.exe",
            "rebased"
        ]
    ],

    "shortcuts": [
        [
            "bin\\rebased64.exe",
            "Rebased"
        ]
    ],

    "checkver": {
        "github": "DetachHead/rebased"
    },

    "autoupdate": {
        "url": "https://gh-proxy.org/https://github.com/DetachHead/rebased/releases/download/$version/rebased.exe"
    }
}